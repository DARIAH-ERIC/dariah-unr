generator client {
  provider = "prisma-client-js"
  seed     = "prisma/seed.ts"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

model Body {
  id      String  @id @default(uuid()) @db.Uuid
  name    String
  acronym String?

  roles Role[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "bodies")
}

model Role {
  id          String @id @default(uuid()) @db.Uuid
  name        String
  annualValue Int // annual money value for given role used for computing countries contribution

  bodies        Body[]
  contributions Contribution[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "roles")
}

// contribution by one person in a specific role in given time frame
model Contribution {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  startDate      DateTime? @map(name: "start_date")
  endDate        DateTime? @map(name: "end_date")
  personId       String    @db.Uuid
  roleId         String    @db.Uuid
  workingGroupId String?    @db.Uuid
  countryId      String?    @db.Uuid

  person       Person        @relation(fields: [personId], references: [id], onDelete: Cascade)
  role         Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  workingGroup WorkingGroup? @relation(fields: [workingGroupId], references: [id], onDelete: Cascade)
  country      Country?      @relation(fields: [countryId], references: [id], onDelete: Cascade) // explicit direct connection to country, because derivation via person's affiliation may be ambiguous or change over time

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "contributions")
}

model Person {
  id    String  @id @default(uuid()) @db.Uuid
  name  String
  // `prisma` currently does not support unique constraints on nullable fields, even though postgres does
  // @see https://github.com/prisma/prisma/issues/3387
  email String? // @unique
  ORCID String?

  contributions Contribution[]
  institutions  Institution[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "persons")
}

model WorkingGroup {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  startDate DateTime? @map(name: "start_date")
  endDate   DateTime? @map(name: "end_date")

  chairs Contribution[] // chair persons connected via contribution (to indicate role and time frame)

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "working_groups")
}

enum InstitutionType {
  cooperating_partner
  national_coordinating_institution
  national_representative_institution
  other // e.g. NC institution or WG chair affiliation
  partner_institution
}

model Institution {
  id        String            @id @default(uuid()) @db.Uuid
  name      String
  types     InstitutionType[]
  startDate DateTime?         @map(name: "start_date")
  endDate   DateTime?         @map(name: "end_date")
  url       String[]
  ROR       String? // global identifier for organisations https://ror.org/

  countries Country[]
  persons   Person[]
  services  InstitutionToService[] // role of institution in providing a service (explicit N:N table)

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "institutions")
}

// role of institution in providing a service (explicit N:N table)
model InstitutionToService {
  id            String           @id @default(uuid()) @db.Uuid
  role          ActorServiceRole
  institutionId String
  serviceId     String

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([institutionId, serviceId, role])
  @@map(name: "institution_service")
}

enum ActorServiceRole {
  service_provider
  service_owner
  technical_contact
  content_provider
}

enum CountryType {
  cooperating_partnership
  member_country
  other
}

model Country {
  id        String      @id @default(uuid()) @db.Uuid
  name      String
  type      CountryType
  startDate DateTime?   @map(name: "start_date")
  endDate   DateTime?   @map(name: "end_date")
  logo      String?

  institutions Institution[]
  outreach     Outreach[]
  services     Service[]
  software     Software[]
  reports      Report[]

  users User[]

  createdAt    DateTime       @default(now()) @map(name: "created_at")
  updatedAt    DateTime       @updatedAt @map(name: "updated_at")
  Contribution Contribution[]

  @@map(name: "countries")
}

enum ServiceType {
  community
  core
  internal
}

enum ServiceStatus {
  discontinued
  in_preparation
  live
  needs_review
  to_be_discontinued
}

enum ServiceAudience {
  dariah_team
  global
  national_local
}

enum ServiceMarketplaceStatus {
  yes
  no
  not_applicable
}

enum ServiceSizeType {
  small
  medium
  large
  core
}

model ServiceSize {
  id          String          @id @default(uuid()) @db.Uuid
  type        ServiceSizeType
  annualValue Int
  Service     Service[]
}

model Service {
  id                String                    @id @default(uuid()) @db.Uuid
  name              String
  type              ServiceType?
  url               String[]
  status            ServiceStatus?
  audience          ServiceAudience?
  agreements        String?
  valueProposition  String?                   @map(name: "value_proposition")
  marketplaceStatus ServiceMarketplaceStatus?
  privateSupplier   Boolean?                  @map(name: "private_supplier")
  trl               Int?
  technical_contact String?
  eosc_onboarding   Boolean?
  monitoring        Boolean?
  dariah_branding   Boolean?
  sizeId            String                    @db.Uuid

  size         ServiceSize?           @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  countries    Country[] // explicit direct connection to country, because derivation via institution may be ambiguous or change over time
  institutions InstitutionToService[]
  reports      ServiceReport[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "services")
}

enum MarketplaceOnboardingStatus {
  added_as_item
  added_as_external_id
  no
  not_applicable
}

enum SoftwareStatus {
  maintained
  not_maintained
  needs_review
}

model Software {
  id                          String                       @id @default(uuid()) @db.Uuid
  name                        String
  url                         String[]
  marketplaceUrl              String?
  comment                     String? // for internal notes
  status                      SoftwareStatus?
  marketplaceOnboardingStatus MarketplaceOnboardingStatus?

  countries Country[] // explicit direct connection to country, because derivation via institution may be ambiguous or change over time *and* relation to institution not introduced yet

  // connection to institutions and countries should be the analogous to service
  // institutions InstitutionToSoftware[]
  // reports   SoftwareReport[] // TODO: assess if dedicated SoftwareReport is needed

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "software")
}

enum OutreachType {
  national_website
  social_media
}

model Outreach {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  url       String
  type      OutreachType
  countryId String       @db.Uuid

  country Country          @relation(fields: [countryId], references: [id], onDelete: Cascade)
  reports OutreachReport[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "outreach")
}

model OutreachReport {
  id         String @id @default(uuid()) @db.Uuid
  outreachId String @db.Uuid
  reportId   String @db.Uuid

  outreach    Outreach      @relation(fields: [outreachId], references: [id], onDelete: Cascade)
  reports     Report
  outreachKpi OutreachKPI[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "outreach_reports")
}

model OutreachKPI {
  id               String @id @default(uuid()) @db.Uuid
  value           Int
  unit            OutreachKpiType
  outreachReportId String @db.Uuid

  outreachReport OutreachReport @relation(fields: [outreachReportId], references: [id], onDelete: Cascade)

  @@map(name: "outreach_kpi")
}

enum ResearchPolicyLevel {
  eu
  national
}

model ResearchPolicyDevelopment {
  id      String              @id @default(uuid()) @db.Uuid
  name    String // policy organisation or effort
  level   ResearchPolicyLevel
  outcome String?

  reportId String @db.Uuid
  report Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)


  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "research_policy_developments")
}

model EventReport {
  id                      String  @id @default(uuid()) @db.Uuid
  smallMeetings           Int?    @map(name: "small_meetings")
  mediumMeetings          Int?    @map(name: "medium_meetings")
  largeMeetings           Int?    @map(name: "large_meetings")
  dariahCommissionedEvent String? @map(name: "dariah_commissioned_event")
  reusableOutcomes        String? @map(name: "reusable_outcomes")
  attendees               Int?

  reportId String @db.Uuid
  report Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "event_reports")
}

enum ProjectScope {
  eu
  national
  regional
}

model ProjectsFundingLeverage {
  id            String        @id @default(uuid()) @db.Uuid
  name          String // project or grant name
  amount        Int? // amount for reporting year
  totalAmount   Int?          @map(name: "total_amount")
  startDate     DateTime?     @map(name: "start_date")
  projectLength Int?          @map(name: "project_length")
  funders       String?
  scope         ProjectScope?

  reportId String @db.Uuid
  report Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "projects_funding_leverage")
}

model ServiceReport {
  id        String @id @default(uuid()) @db.Uuid
  serviceId String @db.Uuid
  reportId String @db.Uuid

  service     Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  report Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)

  serviceKpis ServiceKPI[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "service_reports")
}

enum ServiceKpiType {
  visits
  page_views
  jobs_processed
  websites_hosted
  downloads
  hits
  searches
  sessions
  unique_users
  registered_users
  items
}

model ServiceKPI {
  id              String         @id @default(uuid()) @db.Uuid
  value           Int
  unit            ServiceKpiType
  serviceReportId String         @map(name: "service_report_id") @db.Uuid

  serviceReport ServiceReport @relation(fields: [serviceReportId], references: [id], onDelete: Cascade)

  @@map(name: "service_kpi")
}

enum OutreachKpiType {
  engagement
  reach
  impressions
  followers
  mention
  pageViews
  unique_visitors
  subscribers
  new_content
  views
  watch_time
  posts
}

model Report {
  id        String @id @default(uuid()) @db.Uuid
  year      Int
  comments  Json?  // allows for multiple comments per report (keyed by step)
  countryId String @db.Uuid

  country                    Country                     @relation(fields: [countryId], references: [id], onDelete: Cascade)
  events                     EventReport[]
  projectsFundingLeverage    ProjectsFundingLeverage[]
  services                   ServiceReport[]
  outreach                   OutreachReport[]
  researchPolicyDevelopments ResearchPolicyDevelopment[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@unique([year, countryId])
  @@map(name: "reports")
}

// ------------------------------------------------------------------------------------------------

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map(name: "accounts")
}

